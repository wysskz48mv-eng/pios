# PIOS Environment Configuration Example
# Copy this file to `.env.local` for local development.
# For Vercel, set the same variables in Project Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Core app + auth
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public app URL used in OAuth redirects, emails, and links.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_32_plus_char_random_secret
# Legacy NextAuth compatibility keys (keep set if any legacy auth handlers are enabled).

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Optional fallback key for newer Supabase publishable-key naming.

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_SERVICE_KEY=
# Legacy alias used by some older code paths; set to same value as SUPABASE_SERVICE_ROLE_KEY.

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
# OPENAI_API_KEY and GOOGLE_GEMINI_API_KEY are optional failover providers.

# -----------------------------------------------------------------------------
# Email delivery (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=PIOS <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Google OAuth (Gmail/Calendar/Drive)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# -----------------------------------------------------------------------------
# Microsoft OAuth (Outlook/Graph)
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_app_client_secret
OAUTH_STATE_SECRET=replace_with_32_plus_char_random_secret
# Used to sign OAuth state values for callback integrity.

# -----------------------------------------------------------------------------
# Stripe billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Current pricing keys
STRIPE_PRICE_SPARK=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_EXECUTIVE=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxx

# Legacy fallback pricing keys (keep for backward compatibility)
STRIPE_PRICE_STUDENT=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_TEAM=

# -----------------------------------------------------------------------------
# Security secrets
# -----------------------------------------------------------------------------
CRON_SECRET=replace_with_random_64_hex
ADMIN_SECRET=replace_with_random_64_hex
SEED_SECRET=replace_with_random_64_hex
JWT_SECRET=replace_with_random_64_hex
# CRON_SECRET protects /api/cron/* routes.
# ADMIN_SECRET/SEED_SECRET protect admin/seed routes.
# JWT_SECRET is used by diagnostics/health checks in legacy paths.

# -----------------------------------------------------------------------------
# Feature flags / operational toggles
# -----------------------------------------------------------------------------
ENABLE_ADMIN_ROUTES=false
ENABLE_ADMIN_MIGRATION_ROUTES=false
SUPABASE_IS_SERVICE_KEY=
SENTRY_DSN=
# SUPABASE_IS_SERVICE_KEY is optional for Command Centre live data checks.
# SENTRY_DSN optional for error tracking.
