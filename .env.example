# ═══════════════════════════════════════════════════════
# PIOS v2.2 — Environment Variables
# VeritasIQ Technologies Ltd
# ═══════════════════════════════════════════════════════
# Copy to .env.local for local development
# Set all in Vercel → Settings → Environment Variables

# ── SUPABASE ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://vfvfulbcaurqkygjrrhh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── APP ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pios.veritasiq.tech

# ── STRIPE ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_STUDENT=price_...
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# ── ANTHROPIC ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── RESEND ───────────────────────────────────────────
# Verify domain veritasiq.tech in Resend dashboard first
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@veritasiq.tech

# ── CRON ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── GOOGLE OAUTH (Gmail + Calendar integration) ───────
# Create at console.cloud.google.com → APIs & Credentials → OAuth 2.0
# Enable: Gmail API, Google Calendar API, Google Drive API
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── PIOS-SPECIFIC ─────────────────────────────────────
# Service key for reading live data from VeritasEdge Supabase
SUPABASE_SE_SERVICE_KEY=eyJ...

# ── ANTHROPIC ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AUTH ──────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://pios.veritasiq.tech

# ── GOOGLE OAUTH (calendar + email sync) ──────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── EMAIL (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@veritasiq.tech

# ── CRON (Vercel scheduled jobs) ─────────────────────
CRON_SECRET=generate-strong-random-secret

# ── DIRECT DB (for admin migrations) ─────────────────
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# ── CROSS-PLATFORM LIVE DATA (Sprint 22+) ────────────
# VeritasEdge Supabase service role key (for /api/live/veritasedge)
SUPABASE_SE_SERVICE_KEY=eyJ...
# InvestiScript Supabase service role key (for /api/live/investiscript)
SUPABASE_IS_SERVICE_KEY=eyJ...

# ── OPERATOR MODE (Sprint 25) ────────────────────────
# Set if deploying PIOS under a custom brand/operator config
NEXT_PUBLIC_OPERATOR_SLUG=pios
