# Copy to .env.local for local development
# Set all in Vercel → Settings → Environment Variables

# ── SUPABASE ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://vfvfulbcaurqkygjrrhh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── APP ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pios.sustain-intl.com

# ── STRIPE ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_STUDENT=price_...
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# ── ANTHROPIC ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── RESEND ───────────────────────────────────────────
# Verify domain sustain-intl.com in Resend dashboard first
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@sustain-intl.com

# ── CRON ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── GOOGLE OAUTH (Gmail + Calendar integration) ───────
# Create at console.cloud.google.com → APIs & Credentials → OAuth 2.0
# Enable: Gmail API, Google Calendar API, Google Drive API
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── PIOS-SPECIFIC ─────────────────────────────────────
# Service key for reading live data from VeritasEdge Supabase
SUPABASE_SE_SERVICE_KEY=eyJ...
